---
// Hero — name, eyebrow, three-pillar statement.
// The Three.js canvas (#three-bg) lives inside this section so it
// scrolls away naturally instead of staying pinned across the whole page.
---

<section class="hero reveal">
  <div id="three-bg"></div>

  <div class="hero-inner">
    <div class="hero-eyebrow">
      <div class="hero-dot"></div>
      <span>SOFTWARE ENGINEER</span>
    </div>

    <h1>
      Muhammad<br />
      <span class="last">Salman</span>
    </h1>

    <div class="hero-pillars">
      <div>
        <div class="pillar-label">— DISCIPLINE</div>
        <div class="pillar-text">
          Backend systems &amp;<br />applied machine<br />learning infrastructure.
        </div>
      </div>
      <div>
        <div class="pillar-label">— PRACTICE</div>
        <div class="pillar-text">
          Distributed services,<br />retrieval, the layers<br />that determine scale.
        </div>
      </div>
      <div>
        <div class="pillar-label">— STATUS</div>
        <div class="pillar-text">
          Open to engineering<br />roles &amp; selective<br />collaborations.
        </div>
      </div>
    </div>
  </div>

  <div class="hero-foot">
    <span>↓ &nbsp; CONTINUE</span>
    <span>FIG.&nbsp;01</span>
  </div>
</section>
